{
  "meta": {
    "selection_metric": "mrr",
    "selection_direction": "max",
    "notes": "This file defines a phased sweep plan. A runner should execute phases in order and use the previous phase winner to parameterize the next phase."
  },
  "phases": [
    {
      "id": "phase1_backbone",
      "title": "Backbone selection",
      "description": "Keep baseline settings fixed; vary only the backbone family.",
      "experiments": [
        {
          "name": "p1_mert",
          "description": "Baseline backbone: MERT 95M.",
          "overrides": {
            "backbone": "mert",
            "backbone_checkpoint": "m-a-p/MERT-v1-95M",
            "sampling": "random",
            "loss": "ntxent",
            "augment": "none",
            "augment_mode": "offline",
            "pool": "mean"
          }
        },
        {
          "name": "p1_mert_large",
          "description": "Backbone scale: MERT 330M.",
          "overrides": {
            "backbone": "mert_large",
            "backbone_checkpoint": "m-a-p/MERT-v1-330M",
            "sampling": "random",
            "loss": "ntxent",
            "augment": "none",
            "augment_mode": "offline",
            "pool": "mean"
          }
        },
        {
          "name": "p1_hubert",
          "description": "Backbone comparison: HuBERT base.",
          "overrides": {
            "backbone": "hubert",
            "backbone_checkpoint": "facebook/hubert-base-ls960",
            "sampling": "random",
            "loss": "ntxent",
            "augment": "none",
            "augment_mode": "offline",
            "pool": "mean"
          }
        },
        {
          "name": "p1_ast",
          "description": "Backbone comparison: AST (mel spectrogram backbone).",
          "overrides": {
            "backbone": "ast",
            "backbone_checkpoint": "MIT/ast-finetuned-audioset-10-10-0.4593",
            "sampling": "random",
            "loss": "ntxent",
            "augment": "none",
            "augment_mode": "offline",
            "pool": "mean"
          }
        }
      ],
      "winner_key": "BEST_BACKBONE"
    },
    {
      "id": "phase2_sampling_pool",
      "title": "Data feeding (sampling) and pooling",
      "description": "Fix backbone to Phase 1 winner and compare sampling strategies, then test max pooling.",
      "experiments": [
        {
          "name": "p2_sampling_stratified",
          "description": "Stratified sampling with Phase 1 winner backbone.",
          "uses_winner": "BEST_BACKBONE",
          "overrides": { "sampling": "stratified", "pool": "mean", "loss": "ntxent", "augment": "none", "augment_mode": "offline" }
        },
        {
          "name": "p2_sampling_beat",
          "description": "Beat-aligned sampling with Phase 1 winner backbone.",
          "uses_winner": "BEST_BACKBONE",
          "overrides": { "sampling": "beat", "pool": "mean", "loss": "ntxent", "augment": "none", "augment_mode": "offline" }
        },
        {
          "name": "p2_sampling_mixed",
          "description": "Mixed (variable-length) sampling with Phase 1 winner backbone.",
          "uses_winner": "BEST_BACKBONE",
          "overrides": { "sampling": "mixed", "pool": "mean", "loss": "ntxent", "augment": "none", "augment_mode": "offline" }
        },
        {
          "name": "p2_pool_max",
          "description": "Max pooling ablation using Phase 1 winner backbone and Phase 2 winner sampling.",
          "uses_winner": "BEST_BACKBONE",
          "uses_winner_sampling": "BEST_SAMPLING",
          "overrides": { "pool": "max", "loss": "ntxent", "augment": "none", "augment_mode": "offline" }
        }
      ],
      "winner_key_sampling": "BEST_SAMPLING",
      "winner_key_pool": "BEST_POOL"
    },
    {
      "id": "phase3_loss",
      "title": "Learning signal (loss)",
      "description": "With backbone/sampling/pool locked, compare triplet variants against the already-known NT-Xent result.",
      "experiments": [
        {
          "name": "p3_triplet",
          "description": "Triplet loss with locked backbone/sampling/pool.",
          "uses_winner": "BEST_BACKBONE",
          "uses_winner_sampling": "BEST_SAMPLING",
          "uses_winner_pool": "BEST_POOL",
          "overrides": { "loss": "triplet", "augment": "none", "augment_mode": "offline" }
        },
        {
          "name": "p3_triplet_hard",
          "description": "Hard triplet loss with locked backbone/sampling/pool.",
          "uses_winner": "BEST_BACKBONE",
          "uses_winner_sampling": "BEST_SAMPLING",
          "uses_winner_pool": "BEST_POOL",
          "overrides": { "loss": "triplet_hard", "augment": "none", "augment_mode": "offline" }
        }
      ],
      "winner_key": "BEST_LOSS"
    },
    {
      "id": "phase4_augment",
      "title": "Augmentations",
      "description": "Run time augmentation in offline/online modes for the locked best setup; optionally add AST SpecAugment when backbone is AST.",
      "experiments": [
        {
          "name": "p4_time_offline",
          "description": "Time augmentation, offline mode.",
          "uses_winner": "BEST_BACKBONE",
          "uses_winner_sampling": "BEST_SAMPLING",
          "uses_winner_pool": "BEST_POOL",
          "uses_winner_loss": "BEST_LOSS",
          "overrides": { "augment": "time", "augment_mode": "offline" }
        },
        {
          "name": "p4_time_online",
          "description": "Time augmentation, online mode.",
          "uses_winner": "BEST_BACKBONE",
          "uses_winner_sampling": "BEST_SAMPLING",
          "uses_winner_pool": "BEST_POOL",
          "uses_winner_loss": "BEST_LOSS",
          "overrides": { "augment": "time", "augment_mode": "online" }
        },
        {
          "name": "p4_ast_spec_online",
          "description": "AST-only: SpecAugment, online mode (only valid when backbone is AST).",
          "requires": { "backbone": "ast" },
          "uses_winner": "BEST_BACKBONE",
          "uses_winner_sampling": "BEST_SAMPLING",
          "uses_winner_pool": "BEST_POOL",
          "uses_winner_loss": "BEST_LOSS",
          "overrides": { "augment": "spec", "augment_mode": "online" }
        }
      ]
    }
  ]
}

